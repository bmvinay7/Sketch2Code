NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
DISABLE_AUTH=
NEXT_PUBLIC_BACKEND_URL=http://localhost:4001

# Neon pooled URL — used by the app at runtime
DATABASE_URL=
# Neon direct (non-pooled) URL — used by `prisma migrate` which can't go through the pooler.
# On Neon, find both in the dashboard or via `npx neonctl connection-string [--pooled]`.
DIRECT_DATABASE_URL=

# Optional: leave both blank to use the backend's in-memory cache fallback (fine for demos).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

CLERK_WEBHOOK_SECRET=
